# ============================================
# ORBBI — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ============================================

# --- Supabase ---
# Encontrar en: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Gemini (Google AI) ---
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-api-key-aqui

# --- Stripe (pagos) ---
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Crear productos/precios en Stripe Dashboard y pegar los IDs aquí
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_EQUIPO_MONTHLY=price_...
STRIPE_PRICE_EQUIPO_ANNUAL=price_...
STRIPE_PRICE_EMPRESA_MONTHLY=price_...
STRIPE_PRICE_EMPRESA_ANNUAL=price_...

# --- Resend (emails transaccionales) ---
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_...

# --- PostHog (analytics) ---
# Obtener en: https://us.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Cron ---
CRON_SECRET=your-cron-secret-here

# --- WhatsApp Business API ---
# Obtener en: https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
